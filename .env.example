# Copy to .env.local and fill in. All keys documented below.

# Neon Postgres. DATABASE_URL = pooled connection (runtime), DIRECT_URL = direct (migrations).
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Credentials for the super-admin created by `npm run db:seed`
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""

# Cloudinary (media, PDFs, CV uploads) — https://console.cloudinary.com → Dashboard
# Leave empty to disable uploads gracefully (admin shows a hint instead of the widget).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Resend (email notifications for contact messages & job applications) — https://resend.com
# Leave empty to log notifications to the server console instead of sending.
# NOTE: until a domain is verified at resend.com/domains, Resend only delivers
# to the Resend account owner's own email address (test mode).
RESEND_API_KEY=""
NOTIFICATION_EMAIL="info@safeafrika.com"
# Optional sender override once your domain is verified in Resend:
# EMAIL_FROM="SAFE Africa <website@safeafrika.com>"
